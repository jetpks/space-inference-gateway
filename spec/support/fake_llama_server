#!/usr/bin/env ruby
# frozen_string_literal: true

# Fake llama-server for testing LlamaServerSupervisor.
#
# Usage: fake_llama_server --port PORT [other-llama-server-flags-ignored]
#
# Env:
#   FAKE_UNREADY_POLLS=N  number of /health requests that return 503 before switching
#                         to 200 (default: 3)
#
# Routes:
#   GET  /health                → 503 for the first N requests, then 200
#   GET  /v1/models             → 200 with an empty list
#   POST /v1/chat/completions   → 200, canned OAI response; records request
#   POST /v1/messages           → 200, canned Anthropic response; records request
#   GET  /__requests            → 200, JSON array of recorded {method,path} pairs
#   SIGTERM                     → graceful shutdown

require "webrick"
require "json"

port = nil
args = ARGV.dup
until args.empty?
  arg = args.shift
  port = args.shift.to_i if arg == "--port"
end

abort "Usage: fake_llama_server --port PORT" unless port

unready_polls = Integer(ENV.fetch("FAKE_UNREADY_POLLS", "3"))
health_hits   = 0

CANNED_OAI = JSON.generate({
                             "id" => "chatcmpl-fake",
  "object"            => "chat.completion",
  "created"           => 1_700_000_000,
  "model"             => "fake",
  "choices"           => [{
    "index" => 0,
    "message" => { "role" => "assistant", "content" => "ok", "refusal" => nil },
    "finish_reason" => "stop",
    "logprobs" => nil,
  }],
  "usage" => { "prompt_tokens" => 1, "completion_tokens" => 1, "total_tokens" => 2 },
  "system_fingerprint" => nil,
                           }).freeze

CANNED_ANT = JSON.generate({
                             "id" => "msg-fake",
  "type"          => "message",
  "role"          => "assistant",
  "content"       => [{ "type" => "text", "text" => "ok" }],
  "model"         => "fake",
  "stop_reason"   => "end_turn",
  "stop_sequence" => nil,
  "usage"         => { "input_tokens" => 1, "output_tokens" => 1 },
                           }).freeze

requests_log   = []
requests_mutex = Mutex.new

server = WEBrick::HTTPServer.new(
  Port:      port,
  Logger:    WEBrick::Log.new(File::NULL),
  AccessLog: [],
)

server.mount_proc("/health") do |_req, res|
  health_hits += 1
  if health_hits <= unready_polls
    res.status       = 503
    res.content_type = "application/json"
    res.body         = '{"status":"loading"}'
  else
    res.status       = 200
    res.content_type = "application/json"
    res.body         = '{"status":"ok"}'
  end
end

server.mount_proc("/v1/models") do |_req, res|
  res.status       = 200
  res.content_type = "application/json"
  res.body         = '{"object":"list","data":[]}'
end

server.mount_proc("/v1/chat/completions") do |req, res|
  requests_mutex.synchronize { requests_log << { "method" => req.request_method, "path" => req.path } }
  res.status       = 200
  res.content_type = "application/json"
  res.body         = CANNED_OAI
end

server.mount_proc("/v1/messages") do |req, res|
  requests_mutex.synchronize { requests_log << { "method" => req.request_method, "path" => req.path } }
  res.status       = 200
  res.content_type = "application/json"
  res.body         = CANNED_ANT
end

server.mount_proc("/__requests") do |_req, res|
  list             = requests_mutex.synchronize { requests_log.dup }
  res.status       = 200
  res.content_type = "application/json"
  res.body         = JSON.generate(list)
end

trap("TERM") { server.shutdown }
trap("INT")  { server.shutdown }

server.start
